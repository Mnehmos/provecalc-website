# Clerk Auth
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=YOUR_PUBLISHABLE_KEY
CLERK_SECRET_KEY=YOUR_SECRET_KEY

# ProveCalc API (Railway sidecar URL)
NEXT_PUBLIC_API_URL=http://localhost:9743

# Sign-in/up redirect paths
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Foxit API (Document Generation + PDF Services)
FOXIT_BASE_URL=https://na1.fusion.foxit.com
FOXIT_CLIENT_ID=YOUR_FOXIT_CLIENT_ID
FOXIT_CLIENT_SECRET=YOUR_FOXIT_CLIENT_SECRET

# Stripe (payments)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# License signing — raw 32-byte Ed25519 private key, base64-encoded
# Generate with: python tools/license-keygen.py keygen
# Then encode: python -c "import base64,pathlib; print(base64.b64encode(pathlib.Path('tools/keys/private.key').read_bytes()).decode())"
LICENSE_PRIVATE_KEY=

# Gmail OAuth2 (contact form — free via Google Workspace, no App Password needed)
# Uses the GAM OAuth client. Obtain refresh token by running the oauth flow once.
# See docs/gmail-oauth-setup.md for instructions.
GMAIL_USER=mnehmos@themnemosyneresearchinstitute.com
GMAIL_CLIENT_ID=your-client-id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=GOCSPX-...
GMAIL_REFRESH_TOKEN=1//...

# App URL (for Stripe redirect URLs)
NEXT_PUBLIC_APP_URL=https://provecalc.com
